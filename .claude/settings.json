{
  "enableJsonHooks": true,
  "enable_json_hooks": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".claude/hooks/graphify_pre_tool.py\" --tool Bash --client claude"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".claude/hooks/graphify_pre_tool.py\" --tool Grep --client claude"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".claude/hooks/graphify_pre_tool.py\" --tool Read --client claude"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".claude/hooks/graphify_pre_tool.py\" --tool Write --client claude"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".claude/hooks/graphify_pre_tool.py\" --tool Edit --client claude"
          }
        ]
      }
    ]
  }
}
