{
  "enableJsonHooks": true,
  "enable_json_hooks": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "run_command|run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".gemini/hooks/graphify_pre_tool.py\" --tool Bash --client gemini"
          }
        ]
      },
      {
        "matcher": "view_file|list_dir|read_file|list_directory",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".gemini/hooks/graphify_pre_tool.py\" --tool Read --client gemini"
          }
        ]
      },
      {
        "matcher": "grep_search",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".gemini/hooks/graphify_pre_tool.py\" --tool Grep --client gemini"
          }
        ]
      },
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "# ai-coding-config:graphify-managed\npython3 \".gemini/hooks/graphify_pre_tool.py\" --tool Write --client gemini"
          }
        ]
      }
    ]
  }
}
